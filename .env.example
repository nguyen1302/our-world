# --- Core ---
DATABASE_URL=postgres://ourworld:ourworld@postgres:5432/ourworld
AUTH_SECRET=change-me-to-a-long-random-string
DEFAULT_SPACE_ID=00000000-0000-0000-0000-000000000001

# Hardcoded accounts. JSON array. password_hash = bcrypt hash.
# Example below: admin / "admin123", viewer / "viewer123" (REGENERATE for production!)
USERS=[{"username":"admin","passwordHash":"$2a$10$N9qo8uLOickgx2ZMRZoMy.MQDqxqf3pYwT0kq3eXr5p8z5dQ4yqHe","role":"admin"},{"username":"viewer","passwordHash":"$2a$10$N9qo8uLOickgx2ZMRZoMy.MQDqxqf3pYwT0kq3eXr5p8z5dQ4yqHe","role":"viewer"}]

# --- S3 (or S3-compatible: set S3_ENDPOINT for R2/MinIO) ---
S3_BUCKET=our-world-media
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true

# --- Clustering ---
CLUSTER_DISTANCE_KM=1.5
CLUSTER_TIME_GAP_HOURS=6

# --- Geocode ---
NOMINATIM_USER_AGENT=our-world/0.1 (contact: you@example.com)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# --- Deploy (Caddy) ---
SITE_ADDRESS=ourworld.duckdns.org
